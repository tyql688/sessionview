{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/main/tauri.conf.json",
  "productName": "SessionView",
  "version": "0.6.0",
  "identifier": "com.sessionview.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SessionView — Session Explorer",
        "width": 1200,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.claude/**",
          "$HOME/.codex/**",
          "$HOME/.gemini/**",
          "$HOME/.local/share/opencode/**",
          "$HOME/.kimi-code/**",
          "$HOME/.cursor/**",
          "$HOME/.cc-mirror/**",
          "$HOME/.pi/**"
        ]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": "^(https?://|/)"
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5RjBEOERCRTgwQjg1RTIKUldUaWhRdm8yOWp3bVNjUlViUGFORTNyNGN5Z2p3ckduZlNMWTc3bW41ZTdwQ1MvVmVFTkloZU8K",
      "endpoints": [
        "https://github.com/tyql688/sessionview/releases/latest/download/latest.json"
      ]
    }
  }
}
