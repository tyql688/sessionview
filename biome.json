{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.css",
      "!src/components/**",
      "src/components/icons.tsx",
      "src/components/CodeBlock.tsx",
      "src/components/MermaidBlock.tsx",
      "src/components/MergedToolRow.tsx",
      "src/components/MessageBubble/**",
      "src/components/SessionView/hooks.ts",
      "src/components/SessionView/search-utils.ts",
      "src/components/SessionView/createRoleFilter.ts",
      "src/components/SessionView/useLiveWatch.ts",
      "src/components/SessionView/createSessionPagination.ts",
      "src/components/SessionView/createSessionSearch.ts",
      "src/components/SessionView/useFavoriteSync.ts",
      "src/components/SessionView/useSessionCommandEvents.ts",
      "!**/*.test.ts",
      "!**/*.test.tsx"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "assist": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noArrayIndexKey": "off"
      }
    }
  }
}
