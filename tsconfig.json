{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["katex"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "//": "MIGRATION (migrate/react): base layers always included; ported component files appended per phase. Un-ported Solid components are simply absent from `include`. When all are ported, switch back to include:[\"src\"]. See MIGRATION.md.",
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/vite-env.d.ts",
    "src/lib",
    "src/stores",
    "src/i18n",
    "src/components/icons.tsx",
    "src/components/CodeBlock.tsx",
    "src/components/MermaidBlock.tsx",
    "src/components/MergedToolRow.tsx",
    "src/components/MessageBubble",
    "src/components/SessionView/hooks.ts",
    "src/components/SessionView/search-utils.ts",
    "src/components/SessionView/createRoleFilter.ts",
    "src/components/SessionView/useLiveWatch.ts",
    "src/components/SessionView/createSessionPagination.ts",
    "src/components/SessionView/createSessionSearch.ts",
    "src/components/SessionView/useFavoriteSync.ts",
    "src/components/SessionView/useSessionCommandEvents.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
